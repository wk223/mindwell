# Database — local dev uses SQLite (no install needed)
# For production with PostgreSQL, uncomment these:
# DATABASE_URL=postgresql+asyncpg://mindwell:mindwell_dev@localhost:5432/mindwell
# DATABASE_URL_SYNC=postgresql://mindwell:mindwell_dev@localhost:5432/mindwell
DATABASE_URL=sqlite+aiosqlite:///mindwell.db
DATABASE_URL_SYNC=sqlite:///mindwell.db

# Redis — "memory://" = in-memory fallback (no Redis server needed)
# For production: REDIS_URL=redis://localhost:6379/0
REDIS_URL=memory://

# JWT
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# LLM — Ollama 本地免费大模型
# 安装: https://ollama.com → 拉取模型: ollama pull qwen2.5:7b
# 推荐中文模型: qwen2.5:7b / qwen2.5:14b / deepseek-r1:8b / glm4:9b
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:7b
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7

# App
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=["http://localhost:5173"]
