# ============ MindWell 生产环境配置模板 ============
# 使用方法:
#   1. cp .env.production .env
#   2. 修改下面所有"请修改"的值为强密码/密钥
#   3. 填入 LLM API Key
#
# 生成随机密钥: openssl rand -hex 32
# ==============================================

# ---- PostgreSQL ----
POSTGRES_USER=mindwell
POSTGRES_PASSWORD=请修改为强密码（如 openssl rand -hex 16 的输出）
POSTGRES_DB=mindwell

# ---- JWT ----
JWT_SECRET=请修改为随机字符串（如 openssl rand -hex 32 的输出）

# ---- LLM — DeepSeek API ----
# 获取 Key: https://platform.deepseek.com/api_keys
LLM_API_KEY=你的DeepSeek-API-Key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-pro
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# ---- App ----
APP_ENV=production
APP_DEBUG=false
CORS_ORIGINS=["*"]
