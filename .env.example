# Database
DATABASE_URL=postgresql+asyncpg://mindwell:mindwell_dev@localhost:5432/mindwell
DATABASE_URL_SYNC=postgresql://mindwell:mindwell_dev@localhost:5432/mindwell

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# LLM API (OpenAI-compatible)
LLM_API_KEY=your-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7

# App
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=["http://localhost:5173"]
